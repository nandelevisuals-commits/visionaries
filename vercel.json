{
  "rewrites": [
    {
      "source": "/bde-index",
      "destination": "/bde-index.html"
    },
    {
      "source": "/bde-engine",
      "destination": "/bde-engine.html"
    },
    {
      "source": "/bde-access",
      "destination": "/bde-access.html"
    },
    {
      "source": "/video-studio",
      "destination": "/nandyvisuals-video-studio.html"
    },
    {
      "source": "/ad-studio",
      "destination": "/nandyvisuals-ad-studio.html"
    },
    {
      "source": "/elevated-vision",
      "destination": "/elevated-vision-landing.html"
    },
    {
      "source": "/elevated-vision/access",
      "destination": "/elevated-vision.html"
    },
    {
      "source": "/story-engine",
      "destination": "/story-engine.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}
